---
export interface Props {
  calculatorSlug: string;
  whiteLabel?: boolean;
}

const { calculatorSlug, whiteLabel = false } = Astro.props;
const backlink = `https://boring-math.com/calculators/${calculatorSlug}`;
---

{
  !whiteLabel && (
    <div class="embed-badge">
      <a href={backlink} target="_blank" rel="noopener" class="embed-badge-link">
        <span class="embed-badge-logo">B</span>
        <span class="embed-badge-text">
          Powered by <strong>boring-math.com</strong>
        </span>
      </a>
    </div>
  )
}

<style>
  .embed-badge {
    position: fixed;
    bottom: 8px;
    right: 12px;
    z-index: 50;
  }

  .embed-badge-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 6px;
    background: rgba(20, 20, 26, 0.85);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    text-decoration: none;
    transition:
      border-color 0.2s,
      background 0.2s;
    font-size: 11px;
    line-height: 1;
    color: var(--color-muted);
  }

  .embed-badge-link:hover {
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(20, 20, 26, 0.95);
  }

  .embed-badge-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: var(--color-accent);
    color: var(--color-void);
    font-family: 'Instrument Serif', serif;
    font-size: 12px;
    font-weight: 400;
    flex-shrink: 0;
  }

  .embed-badge-text {
    color: var(--color-muted);
    white-space: nowrap;
  }

  .embed-badge-text strong {
    color: var(--color-cream);
    font-weight: 500;
  }
</style>
