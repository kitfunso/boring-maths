  .faq-item summary::after {
    content: '+';
    color: #6366f1;
    font-size: 1.2rem;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item p {
    margin-top: 0.7rem;
    color: #a0aec0;
    line-height: 1.7;
    font-size: 0.95rem;
  }

