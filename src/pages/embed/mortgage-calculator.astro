---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
import MortgageCalculator from '../../components/calculators/MortgageCalculator/MortgageCalculator';

const slug = 'mortgage-calculator';
const title = 'Mortgage Calculator';
---

<EmbedLayout title={title} calculatorSlug={slug}>
  <div class="max-w-4xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-display text-[var(--color-cream)] mb-6">{title}</h1>
    <MortgageCalculator client:load />
  </div>
</EmbedLayout>
