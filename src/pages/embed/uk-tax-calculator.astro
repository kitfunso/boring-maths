---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
import { UKTaxCalculator } from '../../components/calculators/UKTaxCalculator';

const slug = 'uk-tax-calculator';
const title = 'UK Tax Calculator';
---

<EmbedLayout title={title} calculatorSlug={slug}>
  <div class="max-w-4xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-display text-[var(--color-cream)] mb-6">{title}</h1>
    <UKTaxCalculator client:load />
  </div>
</EmbedLayout>
