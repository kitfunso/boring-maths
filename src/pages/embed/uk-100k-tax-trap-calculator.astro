---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
import { UK100kTaxTrapCalculator } from '../../components/calculators/UK100kTaxTrapCalculator';

const slug = 'uk-100k-tax-trap-calculator';
const title = 'UK £100k Tax Trap Calculator';
---

<EmbedLayout title={title} calculatorSlug={slug}>
  <div class="max-w-4xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-display text-[var(--color-cream)] mb-6">{title}</h1>
    <UK100kTaxTrapCalculator client:load />
  </div>
</EmbedLayout>
