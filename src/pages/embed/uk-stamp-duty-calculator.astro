---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
import { UKStampDutyCalculator } from '../../components/calculators/UKStampDutyCalculator';

const slug = 'uk-stamp-duty-calculator';
const title = 'UK Stamp Duty Calculator';
---

<EmbedLayout title={title} calculatorSlug={slug}>
  <div class="max-w-4xl mx-auto px-4 py-6">
    <h1 class="text-2xl font-display text-[var(--color-cream)] mb-6">{title}</h1>
    <UKStampDutyCalculator client:load />
  </div>
</EmbedLayout>
