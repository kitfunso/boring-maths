---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomepageCurrencySelector from '../components/common/HomepageCurrencySelector';
import {
  calculators,
  getCategories,
  ICON_COLORS as iconColors,
  ICON_PATHS as iconPaths,
  CATEGORY_COLORS as categoryColors,
} from '../lib/calculators';

const title = 'Boring Math Calculators | Free Online Calculators';
const description = 'Free online calculators for everyday math problems. Calculate freelance rates, wedding costs, savings goals, and more. Simple, accurate, and easy to use.';

const categories = getCategories();
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section - Compact on mobile -->
  <section class="relative flex items-center justify-center overflow-hidden px-6 py-2 md:py-4">
    <!-- Floating geometric elements - hidden on mobile -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none hidden md:block" aria-hidden="true">
      <div class="absolute top-20 left-[10%] w-20 h-20 border border-white/10 rounded-2xl rotate-12 animate-float"></div>
      <div class="absolute top-40 right-[15%] w-16 h-16 border border-[var(--color-accent)]/20 rounded-full animate-float" style="animation-delay: -2s;"></div>
      <div class="absolute bottom-32 left-[20%] w-12 h-12 bg-[var(--color-accent)]/10 rounded-lg rotate-45 animate-float" style="animation-delay: -4s;"></div>
      <div class="absolute bottom-48 right-[25%] w-24 h-24 border border-violet-500/20 rounded-3xl -rotate-12 animate-float" style="animation-delay: -1s;"></div>
    </div>

    <div class="relative max-w-6xl mx-auto text-center">
      <!-- Badge - smaller on mobile -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 md:px-4 md:py-2 rounded-full bg-white/5 border border-white/10 mb-1 md:mb-2 animate-slide-up">
        <span class="w-2 h-2 rounded-full bg-[var(--color-accent)] animate-pulse"></span>
        <span class="text-xs md:text-sm text-[var(--color-subtle)]">{calculators.length} Free Calculators</span>
      </div>

      <!-- Main Headline - smaller on mobile -->
      <h1 class="text-2xl md:text-headline mb-2 md:mb-3 animate-slide-up delay-100" style="opacity: 0;">
        <span class="text-[var(--color-cream)]">Boring</span>
        <span class="relative inline-block mx-1 md:mx-2">
          <span class="gradient-text">Math</span>
          <svg class="absolute -bottom-1 left-0 w-full h-2 text-[var(--color-accent)]" viewBox="0 0 100 12" preserveAspectRatio="none">
            <path d="M0,8 Q50,0 100,8" stroke="currentColor" stroke-width="3" fill="none" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="text-[var(--color-cream)]">Made</span>
        <span class="font-display italic text-[var(--color-accent)]"> Easy</span>
      </h1>

      <!-- Subheadline - hidden on mobile -->
      <p class="hidden md:block text-sm text-[var(--color-subtle)] max-w-2xl mx-auto mb-4 animate-slide-up delay-200" style="opacity: 0;">
        Free, simple calculators for freelancers, planners, and anyone who needs
        <span class="text-[var(--color-cream)]">quick answers</span> to everyday math problems.
        <span class="text-[var(--color-accent)]">Fast. Free. Easy.</span>
      </p>

      <!-- Quick Stats - hidden on mobile -->
      <div class="hidden md:grid grid-cols-3 gap-8 max-w-xl mx-auto animate-fade-in delay-300" style="opacity: 0;">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-display text-[var(--color-cream)]">{calculators.length}</div>
          <div class="text-micro text-[var(--color-muted)] mt-1">Calculators</div>
        </div>
        <div class="text-center border-x border-white/10">
          <div class="text-3xl md:text-4xl font-display text-[var(--color-accent)]">Instant</div>
          <div class="text-micro text-[var(--color-muted)] mt-1">Results</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-display text-[var(--color-cream)]">100%</div>
          <div class="text-micro text-[var(--color-muted)] mt-1">Free</div>
        </div>
      </div>

    </div>
  </section>

  <!-- Calculators Section with Category Filter -->
  <section class="relative px-6 py-3 md:py-6" id="calculators">
    <div class="max-w-7xl mx-auto">
      <!-- Search Bar and Currency Selector - Hidden on mobile (search is in header) -->
      <div class="max-w-2xl mx-auto mb-5 hidden md:block">
        <div class="flex items-center gap-3">
          <div class="relative flex-1">
            <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[var(--color-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input
              type="text"
              id="search-input"
              placeholder="Search calculators..."
              class="w-full pl-12 pr-4 py-4 bg-[var(--color-charcoal)] border border-white/10 rounded-2xl
                     text-[var(--color-cream)] placeholder:text-[var(--color-muted)]
                     focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20
                     transition-all duration-300"
            />
            <button
              id="clear-search"
              class="absolute right-4 top-1/2 -translate-y-1/2 text-[var(--color-muted)] hover:text-[var(--color-cream)] hidden"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <!-- Global Currency Selector -->
          <HomepageCurrencySelector client:idle />
        </div>
      </div>
      <!-- Recent Section (hidden by default, shown via JS) -->
      <div id="recently-used-section" class="hidden mb-5">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-xs font-medium text-[var(--color-muted)] uppercase tracking-wider flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Recently Used
          </h2>
          <button id="clear-recent" class="text-xs text-[var(--color-muted)] hover:text-[var(--color-cream)] transition-colors">
            Clear
          </button>
        </div>
        <!-- Mobile: horizontal scrolling ticker, Desktop: wrapped grid -->
        <div id="recently-used-grid" class="flex gap-2 overflow-x-auto pb-2 -mx-6 px-6 md:mx-0 md:px-0 md:flex-wrap md:overflow-visible scrollbar-hide snap-x snap-mandatory md:snap-none">
          <!-- Populated by JavaScript -->
        </div>
      </div>

      <!-- Mobile Filter Toggle + Currency Selector Row -->
      <div class="md:hidden mb-3 flex items-center gap-2">
        <button
          id="mobile-filter-toggle"
          class="flex-1 flex items-center justify-between px-3 py-2 rounded-xl bg-[var(--color-charcoal)] border border-white/10 text-[var(--color-cream)]"
        >
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-[var(--color-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
            <span class="text-xs font-medium">Filter</span>
            <span id="active-filter-badge" class="hidden px-1.5 py-0.5 rounded-full bg-[var(--color-accent)] text-[var(--color-void)] text-[10px] font-medium"></span>
          </span>
          <svg id="filter-chevron" class="w-4 h-4 text-[var(--color-muted)] transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <HomepageCurrencySelector client:idle />
      </div>

      <!-- Category Filter - hidden on mobile by default, shown on desktop -->
      <div id="filter-panel" class="hidden md:flex md:flex-wrap md:justify-center gap-2 mb-2 overflow-x-auto pb-2 md:pb-0 -mx-6 px-6 md:mx-0 md:px-0 scrollbar-hide transition-all duration-300 ease-out">
        <!-- Favorites toggle -->
        <button
          class="category-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 border
                 text-[var(--color-subtle)] bg-transparent border-white/10 hover:border-white/20 hover:text-[var(--color-cream)]
                 flex items-center gap-2"
          data-category="Favorites"
          id="favorites-filter"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
          Favorites
        </button>
        {categories.map((category, index) => (
          <button
            class:list={[
              "category-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 border",
              index === 0
                ? "text-[var(--color-void)] bg-[var(--color-accent)] border-transparent"
                : "text-[var(--color-subtle)] bg-transparent border-white/10 hover:border-white/20 hover:text-[var(--color-cream)]"
            ]}
            data-category={category}
          >
            {category}
          </button>
        ))}

      </div>

      <!-- Region Filter - hidden on mobile by default, shown on desktop -->
      <div id="region-filter-panel" class="hidden md:flex md:flex-wrap md:justify-center gap-2 mb-4 md:mb-6 overflow-x-auto -mx-6 px-6 md:mx-0 md:px-0 scrollbar-hide transition-all duration-300 ease-out">
        <span class="text-xs text-[var(--color-muted)] uppercase tracking-wider mr-2 self-center">Region:</span>
        <button
          class="category-btn px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-300 border
                 text-[var(--color-subtle)] bg-transparent border-white/10 hover:border-white/20 hover:text-[var(--color-cream)]"
          data-category="US"
          data-country="US"
        >
          US
        </button>
        <button
          class="category-btn px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-300 border
                 text-[var(--color-subtle)] bg-transparent border-white/10 hover:border-white/20 hover:text-[var(--color-cream)]"
          data-category="UK"
          data-country="UK"
        >
          UK
        </button>
        <button
          class="category-btn px-3 py-1.5 rounded-full text-xs font-medium transition-all duration-300 border
                 text-[var(--color-subtle)] bg-transparent border-white/10 hover:border-white/20 hover:text-[var(--color-cream)]"
          data-category="EU"
          data-country="EU"
        >
          EU
        </button>
      </div>

      <!-- Calculators Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-4" id="calculators-grid">
        {calculators.map((calc, index) => (
          <>
            <div
              class="calculator-card bento-card group relative glow"
              data-category={calc.category}
              data-title={calc.title.toLowerCase()}
              data-description={calc.description.toLowerCase()}
              data-href={calc.href}
              data-country={calc.country || 'all'}
              style={`animation-delay: ${Math.min(index * 30, 600)}ms;`}
            >
              <!-- Top row: Category + Star -->
              <div class="absolute top-5 right-5 flex items-center gap-2 z-10">
                <div class={`px-3 py-1 rounded-full text-xs font-medium border ${categoryColors[calc.category]}`}>
                  {calc.category}
                </div>
                <button
                  class="favorite-btn w-7 h-7 rounded-full bg-white/5 flex items-center justify-center
                         hover:bg-[var(--color-accent)]/20 transition-all duration-300"
                  data-calc-id={calc.href}
                  aria-label="Add to favorites"
                >
                  <svg class="w-3.5 h-3.5 favorite-icon text-[var(--color-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  </svg>
                </button>
              </div>

              <!-- Main card link -->
              <a href={calc.href} class="block">
                <!-- Icon -->
                <div class:list={[
                  "card-icon",
                  `bg-gradient-to-br ${iconColors[calc.color]}`
                ]}>
                  <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[calc.icon]} />
                  </svg>
                </div>

                <!-- Content -->
                <h3 class="font-display text-xl text-[var(--color-cream)] mb-2 group-hover:text-[var(--color-accent)] transition-colors text-left">
                  {calc.title}
                </h3>
                <p class="text-sm text-[var(--color-subtle)] leading-relaxed mb-4 text-left">
                  {calc.description}
                </p>

                <!-- Bottom: Most Used badge + Arrow -->
                <div class="flex items-center justify-between mt-auto pt-2">
                  {calc.mostUsed ? (
                    <div class="px-2 py-0.5 rounded-full bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20">
                      <span class="text-xs text-[var(--color-accent)] font-medium">Most Used</span>
                    </div>
                  ) : (
                    <div></div>
                  )}
                  <div class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center group-hover:bg-[var(--color-accent)] transition-all duration-500">
                    <svg class="w-4 h-4 text-[var(--color-subtle)] group-hover:text-[var(--color-void)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </div>
                </div>
              </a>
            </div>
          </>
        ))}
      </div>

      <!-- Empty State (hidden by default) -->
      <div id="empty-state" class="hidden text-center py-16">
        <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-[var(--color-muted)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-[var(--color-subtle)]">No calculators found in this category.</p>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="relative px-6 py-20">
    <div class="max-w-7xl mx-auto">
      <!-- Section Header -->
      <div class="text-center mb-16">
        <span class="text-micro text-[var(--color-accent)] mb-4 block">Why Boring Math?</span>
        <h2 class="text-headline text-[var(--color-cream)] mb-4">Built Different</h2>
        <p class="text-[var(--color-subtle)] max-w-xl mx-auto">
          We believe calculators should be fast, beautiful, and respect your privacy.
        </p>
      </div>

      <!-- Features Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="glass rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-title text-[var(--color-cream)] mb-3">Instant Results</h3>
          <p class="text-[var(--color-subtle)]">
            Results update as you type. No submit buttons, no page reloads, no waiting.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="glass rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-500 to-emerald-600 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-title text-[var(--color-cream)] mb-3">100% Private</h3>
          <p class="text-[var(--color-subtle)]">
            All calculations happen in your browser. We never see, store, or sell your data.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="glass rounded-2xl p-8 text-center">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-title text-[var(--color-cream)] mb-3">Made with Care</h3>
          <p class="text-[var(--color-subtle)]">
            Every calculator is thoughtfully designed for real-world use cases and accuracy.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative px-6 py-8">
    <div class="max-w-4xl mx-auto">
      <div class="relative card-elevated rounded-3xl p-8 md:p-12 text-center overflow-hidden">
        <!-- Background decoration -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
          <div class="absolute -top-24 -right-24 w-64 h-64 bg-[var(--color-accent)]/10 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-violet-500/10 rounded-full blur-3xl"></div>
        </div>

        <div class="relative">
          <h2 class="text-headline text-[var(--color-cream)] mb-4">
            Ready to make math <span class="text-[var(--color-accent)]">easy</span>?
          </h2>
          <p class="text-[var(--color-subtle)] text-lg mb-8 max-w-xl mx-auto">
            Pick a calculator above and get your answer in seconds. It's free, it's fast, and it just works.
          </p>
          <a href="#calculators" class="btn-primary inline-flex">
            <span>Browse Calculators</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Calculator filtering, search, favorites, and recently used functionality
  function initCalculatorPage() {
    const filterButtons = document.querySelectorAll('.category-btn');
    const calculatorCards = document.querySelectorAll('.calculator-card');
    const emptyState = document.getElementById('empty-state');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const headerSearchInput = document.getElementById('header-search-input') as HTMLInputElement;
    const clearSearch = document.getElementById('clear-search');
    const favoritesFilter = document.getElementById('favorites-filter');
    const recentlyUsedSection = document.getElementById('recently-used-section');
    const recentlyUsedGrid = document.getElementById('recently-used-grid');
    const clearRecentBtn = document.getElementById('clear-recent');

    // Mobile filter toggle
    const mobileFilterToggle = document.getElementById('mobile-filter-toggle');
    const filterPanel = document.getElementById('filter-panel');
    const regionFilterPanel = document.getElementById('region-filter-panel');
    const filterChevron = document.getElementById('filter-chevron');
    const activeFilterBadge = document.getElementById('active-filter-badge');
    let filtersExpanded = false;

    // Reset filter panel state on page load (fixes back navigation issue)
    function resetFilterState() {
      filtersExpanded = false;
      filterPanel?.classList.add('hidden');
      filterPanel?.classList.remove('flex', 'flex-wrap');
      regionFilterPanel?.classList.add('hidden');
      regionFilterPanel?.classList.remove('flex', 'flex-wrap');
      filterChevron?.classList.remove('rotate-180');

      // Reset all filter buttons to default state
      filterButtons.forEach(btn => {
        const category = btn.getAttribute('data-category');
        if (category === 'All') {
          btn.classList.remove('text-[var(--color-subtle)]', 'bg-transparent', 'border-white/10');
          btn.classList.add('text-[var(--color-void)]', 'bg-[var(--color-accent)]', 'border-transparent');
        } else if (category !== 'Favorites') {
          btn.classList.add('text-[var(--color-subtle)]', 'bg-transparent', 'border-white/10');
          btn.classList.remove('text-[var(--color-void)]', 'bg-[var(--color-accent)]', 'bg-violet-500', 'border-transparent');
        }
      });

      // Reset favorites button
      if (favoritesFilter) {
        favoritesFilter.classList.add('text-[var(--color-subtle)]', 'bg-transparent', 'border-white/10');
        favoritesFilter.classList.remove('text-[var(--color-void)]', 'bg-[var(--color-accent)]', 'border-transparent');
      }

      // Reset active filter badge
      activeFilterBadge?.classList.add('hidden');

      // Clear search inputs (desktop and header)
      if (searchInput) {
        searchInput.value = '';
      }
      if (headerSearchInput) {
        headerSearchInput.value = '';
      }
      clearSearch?.classList.add('hidden');

      // Show all calculator cards
      calculatorCards.forEach(card => {
        card.classList.remove('hidden');
      });

      // Show all ads
      // Hide empty state
      emptyState?.classList.add('hidden');
    }

    // Initialize with reset state
    resetFilterState();

    function toggleMobileFilters() {
      filtersExpanded = !filtersExpanded;
      if (filtersExpanded) {
        filterPanel?.classList.remove('hidden');
        filterPanel?.classList.add('flex', 'flex-wrap');
        regionFilterPanel?.classList.remove('hidden');
        regionFilterPanel?.classList.add('flex', 'flex-wrap');
        filterChevron?.classList.add('rotate-180');
      } else {
        filterPanel?.classList.add('hidden');
        filterPanel?.classList.remove('flex', 'flex-wrap');
        regionFilterPanel?.classList.add('hidden');
        regionFilterPanel?.classList.remove('flex', 'flex-wrap');
        filterChevron?.classList.remove('rotate-180');
      }
    }

    function updateActiveFilterBadge(filterName: string | null) {
      if (activeFilterBadge) {
        if (filterName && filterName !== 'All') {
          activeFilterBadge.textContent = filterName;
          activeFilterBadge.classList.remove('hidden');
        } else {
          activeFilterBadge.classList.add('hidden');
        }
      }
    }

    mobileFilterToggle?.addEventListener('click', toggleMobileFilters);

    // Storage keys
    const FAVORITES_KEY = 'boring-math-favorites';
    const RECENT_KEY = 'boring-math-recent';
    const MAX_RECENT = 4;

    // Calculator data for recently used display
    const calculatorData: Record<string, { title: string; icon: string; color: string }> = {};
    calculatorCards.forEach(card => {
      const href = card.getAttribute('data-href');
      const title = card.querySelector('h3')?.textContent || '';
      const iconEl = card.querySelector('.card-icon');
      const iconPath = card.querySelector('.card-icon svg path')?.getAttribute('d') || '';
      const colorClass = iconEl?.className.match(/from-(\w+)-/)?.[1] || 'blue';
      if (href) {
        calculatorData[href] = { title, icon: iconPath, color: colorClass };
      }
    });

    // Recently used management
    interface RecentItem {
      href: string;
      timestamp: number;
    }

    function getRecentlyUsed(): RecentItem[] {
      try {
        return JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function saveRecentlyUsed(recent: RecentItem[]) {
      localStorage.setItem(RECENT_KEY, JSON.stringify(recent));
    }

    function addToRecentlyUsed(href: string) {
      let recent = getRecentlyUsed();
      // Remove if already exists
      recent = recent.filter(item => item.href !== href);
      // Add to front
      recent.unshift({ href, timestamp: Date.now() });
      // Keep only MAX_RECENT items
      recent = recent.slice(0, MAX_RECENT);
      saveRecentlyUsed(recent);
    }

    function clearRecentlyUsed() {
      localStorage.removeItem(RECENT_KEY);
      renderRecentlyUsed();
    }

    const colorGradients: Record<string, string> = {
      blue: 'from-blue-500 to-blue-600',
      green: 'from-emerald-500 to-emerald-600',
      emerald: 'from-emerald-500 to-emerald-600',
      violet: 'from-violet-500 to-purple-600',
      purple: 'from-violet-500 to-purple-600',
      rose: 'from-rose-500 to-red-500',
      red: 'from-rose-500 to-red-500',
      coral: 'from-rose-500 to-red-500',
      cyan: 'from-cyan-500 to-teal-500',
      teal: 'from-cyan-500 to-teal-500',
      ocean: 'from-cyan-500 to-teal-500',
      amber: 'from-amber-500 to-orange-500',
      orange: 'from-amber-500 to-orange-500',
      pink: 'from-pink-500 to-rose-500',
    };

    function createRecentCard(item: RecentItem, data: { title: string; icon: string; color: string }) {
      const gradient = colorGradients[data.color] || colorGradients.blue;
      const displayTitle = data.title.replace(/\s*Calculator$/i, '');

      const link = document.createElement('a');
      link.href = item.href;
      link.className =
        'recent-card glass rounded-lg px-3 py-2 flex items-center gap-2 hover:bg-white/10 transition-all group flex-shrink-0 snap-start whitespace-nowrap';

      const iconContainer = document.createElement('div');
      iconContainer.className = `w-6 h-6 rounded-md bg-gradient-to-br ${gradient} flex items-center justify-center flex-shrink-0`;

      const svgNS = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(svgNS, 'svg');
      svg.setAttribute('class', 'w-3.5 h-3.5 text-white');
      svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor');
      svg.setAttribute('viewBox', '0 0 24 24');

      const path = document.createElementNS(svgNS, 'path');
      path.setAttribute('stroke-linecap', 'round');
      path.setAttribute('stroke-linejoin', 'round');
      path.setAttribute('stroke-width', '1.5');
      path.setAttribute('d', data.icon);
      svg.appendChild(path);

      iconContainer.appendChild(svg);

      const titleSpan = document.createElement('span');
      titleSpan.className =
        'text-xs text-[var(--color-cream)] group-hover:text-[var(--color-accent)] transition-colors';
      titleSpan.textContent = displayTitle;

      link.appendChild(iconContainer);
      link.appendChild(titleSpan);

      return link;
    }

    function renderRecentlyUsed() {
      const recent = getRecentlyUsed();

      if (!recentlyUsedSection || !recentlyUsedGrid) return;

      if (recent.length === 0) {
        recentlyUsedSection.classList.add('hidden');
        return;
      }

      recentlyUsedSection.classList.remove('hidden');

      recentlyUsedGrid.textContent = '';

      recent.forEach(item => {
        const data = calculatorData[item.href];
        if (!data) return;
        recentlyUsedGrid.appendChild(createRecentCard(item, data));
      });
    }

    // Track calculator clicks
    calculatorCards.forEach(card => {
      const link = card.querySelector('a');
      const href = card.getAttribute('data-href');
      if (link && href) {
        link.addEventListener('click', () => {
          addToRecentlyUsed(href);
        });
      }
    });

    // Clear recently used button
    clearRecentBtn?.addEventListener('click', clearRecentlyUsed);

    // Initialize recently used on page load
    renderRecentlyUsed();

    // Mark cards as loaded after initial animation to enable instant filtering
    setTimeout(() => {
      calculatorCards.forEach(card => card.classList.add('loaded'));
    }, 800);

    // Favorites management

    function getFavorites(): string[] {
      try {
        return JSON.parse(localStorage.getItem(FAVORITES_KEY) || '[]');
      } catch {
        return [];
      }
    }

    function saveFavorites(favorites: string[]) {
      localStorage.setItem(FAVORITES_KEY, JSON.stringify(favorites));
    }

    function toggleFavorite(calcId: string) {
      const favorites = getFavorites();
      const index = favorites.indexOf(calcId);
      if (index === -1) {
        favorites.push(calcId);
      } else {
        favorites.splice(index, 1);
      }
      saveFavorites(favorites);
      updateFavoriteButtons();
    }

    function updateFavoriteButtons() {
      const favorites = getFavorites();
      document.querySelectorAll('.favorite-btn').forEach(btn => {
        const calcId = btn.getAttribute('data-calc-id');
        const icon = btn.querySelector('.favorite-icon');
        if (calcId && favorites.includes(calcId)) {
          icon?.classList.remove('text-[var(--color-muted)]');
          icon?.classList.add('text-[var(--color-accent)]');
          icon?.setAttribute('fill', 'currentColor');
        } else {
          icon?.classList.add('text-[var(--color-muted)]');
          icon?.classList.remove('text-[var(--color-accent)]');
          icon?.setAttribute('fill', 'none');
        }
      });
    }

    // Initialize favorite buttons
    updateFavoriteButtons();

    // Favorite button click handlers
    document.querySelectorAll('.favorite-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const calcId = btn.getAttribute('data-calc-id');
        if (calcId) {
          toggleFavorite(calcId);
        }
      });
    });

    // Current filter state
    let currentCategory = 'All';
    let currentSearch = '';
    let showingFavorites = false;
    let currentCountry = 'all';

    function filterCards() {
      const favorites = getFavorites();
      let visibleCount = 0;
      const isFiltered = currentCategory !== 'All' || currentSearch || showingFavorites || currentCountry !== 'all';

      calculatorCards.forEach(card => {
        const cardCategory = card.getAttribute('data-category');
        const cardTitle = card.getAttribute('data-title') || '';
        const cardDescription = card.getAttribute('data-description') || '';
        const cardHref = card.getAttribute('data-href') || '';
        const cardCountry = card.getAttribute('data-country') || 'all';

        // Check category filter
        const matchesCategory = currentCategory === 'All' || cardCategory === currentCategory;

        // Check search filter (matches title, description, or category)
        const searchLower = currentSearch.toLowerCase();
        const categoryLower = (cardCategory || '').toLowerCase();
        const matchesSearch = !currentSearch ||
          cardTitle.includes(searchLower) ||
          cardDescription.includes(searchLower) ||
          categoryLower.includes(searchLower);

        // Check favorites filter
        const matchesFavorites = !showingFavorites || favorites.includes(cardHref);

        // Check country filter
        const matchesCountry = currentCountry === 'all' || cardCountry === currentCountry;

        if (matchesCategory && matchesSearch && matchesFavorites && matchesCountry) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Show/hide empty state
      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
    }

    // Category filter click handlers
    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');

        if (category === 'Favorites') {
          showingFavorites = !showingFavorites;
          if (showingFavorites) {
            button.classList.remove('text-[var(--color-subtle)]', 'bg-transparent', 'border-white/10');
            button.classList.add('text-[var(--color-void)]', 'bg-[var(--color-accent)]', 'border-transparent');
            updateActiveFilterBadge('Favorites');
          } else {
            button.classList.add('text-[var(--color-subtle)]', 'bg-transparent', 'border-white/10');
            button.classList.remove('text-[var(--color-void)]', 'bg-[var(--color-accent)]', 'border-transparent');
            updateActiveFilterBadge(currentCategory !== 'All' ? currentCategory : (currentCountry !== 'all' ? currentCountry : null));
          }
        } else {
          const isCountryFilter = button.hasAttribute("data-country");

          if (isCountryFilter) {
            currentCategory = "All";
            currentCountry = button.getAttribute("data-country") || "all";
            updateActiveFilterBadge(currentCountry !== 'all' ? currentCountry : null);
          } else {
            currentCategory = category || "All";
            currentCountry = "all";
            updateActiveFilterBadge(currentCategory !== 'All' ? currentCategory : null);
          }
          showingFavorites = false;

          // Update button styles
          filterButtons.forEach(btn => {
            if (btn.getAttribute("data-category") !== "Favorites") {
              btn.classList.remove("text-[var(--color-void)]", "bg-[var(--color-accent)]", "bg-violet-500", "border-transparent");
              btn.classList.add("text-[var(--color-subtle)]", "bg-transparent", "border-white/10");
            }
          });

          // Highlight selected (violet for country, accent for category)
          button.classList.remove("text-[var(--color-subtle)]", "bg-transparent", "border-white/10");
          if (isCountryFilter) {
            button.classList.add("text-[var(--color-void)]", "bg-violet-500", "border-transparent");
          } else {
            button.classList.add("text-[var(--color-void)]", "bg-[var(--color-accent)]", "border-transparent");
          }

          // Reset favorites filter button
          if (favoritesFilter) {
            favoritesFilter.classList.add("text-[var(--color-subtle)]", "bg-transparent", "border-white/10");
            favoritesFilter.classList.remove("text-[var(--color-void)]", "bg-[var(--color-accent)]", "border-transparent");
          }
        }

        filterCards();

        // Auto-collapse filters on mobile after selection
        if (window.innerWidth < 768 && filtersExpanded) {
          toggleMobileFilters();
        }
      });
    });

    // Search functionality - sync both desktop and header (mobile) search inputs
    function handleSearch(value: string) {
      currentSearch = value;
      filterCards();

      // Sync both inputs
      if (searchInput && searchInput.value !== value) searchInput.value = value;
      if (headerSearchInput && headerSearchInput.value !== value) headerSearchInput.value = value;

      // Show/hide clear button
      if (clearSearch) {
        clearSearch.classList.toggle('hidden', !currentSearch);
      }
    }

    searchInput?.addEventListener('input', () => handleSearch(searchInput.value));
    headerSearchInput?.addEventListener('input', () => handleSearch(headerSearchInput.value));

    clearSearch?.addEventListener('click', () => {
      handleSearch('');
      if (searchInput) {
        clearSearch?.classList.add('hidden');
        searchInput.focus();
      }
    });
  }

  // Initialize on DOMContentLoaded
  document.addEventListener('DOMContentLoaded', initCalculatorPage);

  // Re-initialize after Astro View Transitions navigation
  document.addEventListener('astro:page-load', initCalculatorPage);

  // Re-initialize on back/forward navigation (fixes filter state)
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      initCalculatorPage();
    }
  });
</script>

<style>
  /* Animation for initial load */
  @keyframes hero-slide-up {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-slide-up {
    animation: hero-slide-up 0.8s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  .animate-fade-in {
    animation: fade-in 0.6s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .calculator-card {
    animation: card-appear 0.5s cubic-bezier(0.19, 1, 0.22, 1) forwards;
    opacity: 0;
  }

  /* After initial load, disable animation for instant filtering */
  .calculator-card.loaded {
    animation: none;
    opacity: 1;
    transform: none;
  }

  @keyframes card-appear {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
