---
/**
 * EU Salary Calculator Page
 * Compare net salary across European countries
 */

import CalculatorLayout from '../../layouts/CalculatorLayout.astro';
import SEOHead from '../../components/common/SEOHead.astro';
import HeroSection from '../../components/calculators/shared/HeroSection.astro';
import ContentSection from '../../components/calculators/shared/ContentSection.astro';
import FAQSection from '../../components/calculators/shared/FAQSection.astro';
import { EUSalaryCalculator } from '../../components/calculators/EUSalaryCalculator';

const title = 'EU Salary Calculator 2025/2026: Compare Net Pay Across Europe';
const description =
  'Use this EU salary calculator to compare gross vs net pay across Europe. Check 2025 and 2026 take-home estimates for Germany, France, Netherlands, Spain, Italy, and 20+ other countries.';
const keywords =
  'eu salary calculator, eu salary calculator 2025, eu salary calculator 2026, net salary europe, germany salary calculator, france salary calculator, netherlands salary calculator, european tax calculator, take home pay europe, net pay calculator eu, brutto netto rechner';
const canonicalURL = '/calculators/eu-salary-calculator';
const siteUrl = 'https://boring-math.com';

const breadcrumbs = [
  { label: 'Calculators', href: '/calculators' },
  { label: 'EU Salary Calculator' },
];

const relatedCalculators = [
  {
    title: 'EU VAT Calculator',
    description: 'Calculate VAT for EU countries.',
    href: '/calculators/eu-vat-calculator',
    icon: 'percent' as const,
    color: 'blue' as const,
  },
  {
    title: 'Contractor vs Employee',
    description: 'Compare contractor rates vs salary.',
    href: '/calculators/contractor-vs-employee-calculator',
    icon: 'swap' as const,
    color: 'green' as const,
  },
  {
    title: 'FIRE Calculator',
    description: 'Work out your financial independence number.',
    href: '/calculators/fire-calculator',
    icon: 'trending' as const,
    color: 'amber' as const,
  },
  {
    title: 'UK Tax Calculator',
    description: 'Calculate take-home pay in the UK.',
    href: '/calculators/uk-tax-calculator',
    icon: 'calculator' as const,
    color: 'purple' as const,
  },
];

const faqs = [
  {
    question: 'Which EU country has the lowest taxes?',
    answer:
      'For employees, Bulgaria (10% flat tax) and Hungary (15% flat tax) have the lowest income tax rates. However, social security contributions vary. Ireland and Portugal offer favourable tax regimes for certain workers and digital nomads.',
  },
  {
    question: 'How is salary taxed in Germany?',
    answer:
      'Germany uses progressive tax brackets from 14% to 45% (plus 5.5% solidarity surcharge). Social contributions (pension, health, unemployment, care insurance) add about 20% for employees. The tax-free allowance is €11,604 (2024). Married couples can benefit from income splitting (Ehegattensplitting).',
  },
  {
    question: 'What is the difference between gross and net salary?',
    answer:
      'Gross salary is your total pay before any deductions. Net salary (take-home pay) is what you receive after income tax, social security contributions, and other mandatory deductions. In high-tax EU countries, net can be 50-60% of gross.',
  },
  {
    question: 'Do EU countries have social security agreements?',
    answer:
      'Yes, EU regulations coordinate social security between member states. You generally pay contributions in the country where you work. Posted workers and cross-border workers have special rules. Periods of contribution in different countries count toward benefits.',
  },
  {
    question: 'How does the Netherlands salary system work?',
    answer:
      "The Netherlands has a relatively high tax wedge with income tax up to 49.5% and significant social contributions. However, there's the 30% ruling for skilled migrants which can make a portion of salary tax-free for up to 5 years.",
  },
  {
    question: 'What is the 13th month salary in Europe?',
    answer:
      "Some EU countries traditionally pay a 13th month salary (or 14th in some cases). This is common in Spain, Portugal, Italy, Austria, and Greece. It's usually part of annual compensation, paid in December or split between summer and winter. Our calculator uses annual figures.",
  },
  {
    question: 'Is this EU salary calculator updated for 2025 and 2026?',
    answer:
      'Yes. The calculator is designed for current cross-country comparison and is useful for both 2025 and 2026 salary planning. Tax rules change at different times across Europe, so treat the results as strong planning estimates rather than payroll-grade figures, especially if your country has local taxes, family allowances, or special expat regimes.',
  },
  {
    question: 'How accurate are these calculations?',
    answer:
      'These are simplified estimates for comparison purposes. Actual take-home pay depends on factors like marital status, children, local or municipal taxes, pension contributions, health insurance choices, and specific deductions. Consult a local tax advisor for precise calculations.',
  },
  {
    question: 'Can I compare salaries between EU and non-EU countries?',
    answer:
      'This calculator focuses on EU countries. For US comparison, see our US Tax Bracket Calculator. Remember that direct salary comparison should also consider cost of living, healthcare costs, and benefits that may be included (or not) in different countries.',
  },
];

const schemaBreadcrumbs = [
  { name: 'Calculators', url: '/calculators' },
  { name: 'EU Salary Calculator', url: canonicalURL },
];
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalURL={canonicalURL}
  breadcrumbs={breadcrumbs}
  relatedCalculators={relatedCalculators}
>
  <SEOHead
    slot="schema"
    name="EU Salary Calculator"
    description={description}
    url={`${siteUrl}${canonicalURL}`}
    faqs={faqs}
    breadcrumbs={schemaBreadcrumbs}
  />

  <HeroSection
    title="EU Salary Calculator"
    description="Compare 2025 and 2026 net salary estimates across European countries. See how much you'd take home after tax and social security in Germany, France, Netherlands, and more."
  />

  <section class="mb-16" aria-label="Calculator">
    <EUSalaryCalculator client:load />
  </section>

  <ContentSection title="Understanding EU Salaries">
    <p>
      Salary structures vary significantly across EU member states. While gross salaries might look
      similar, net take-home pay can differ by 20-30% due to varying tax rates, social security
      systems, and deductions.
    </p>
    <h3 class="text-lg font-semibold mt-4 mb-2">Key Factors Affecting Net Pay</h3>
    <ul class="list-disc list-inside space-y-1">
      <li>
        <strong>Income Tax:</strong> Progressive rates from 10% (Bulgaria) to 57% (Denmark top rate)
      </li>
      <li>
        <strong>Social Security:</strong> Employee contributions range from 4% (Ireland) to 27% (Netherlands)
      </li>
      <li><strong>Tax-Free Allowances:</strong> Vary from €0 to €30,000+ depending on country</li>
      <li><strong>Local Taxes:</strong> Some countries have municipal or regional income taxes</li>
    </ul>
  </ContentSection>

  <ContentSection title="Highest and Lowest Tax Countries">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-900/20 rounded-lg p-4">
        <h4 class="font-semibold text-green-400 mb-2">Lower Tax Burden</h4>
        <ul class="text-sm space-y-1 text-[var(--color-subtle)]">
          <li>Bulgaria - 10% flat tax</li>
          <li>Hungary - 15% flat tax</li>
          <li>Romania - 10% flat tax</li>
          <li>Ireland - Lower rates + tech sector benefits</li>
          <li>Portugal - NHR regime for new residents</li>
        </ul>
      </div>
      <div class="bg-red-900/20 rounded-lg p-4">
        <h4 class="font-semibold text-red-400 mb-2">Higher Tax Burden</h4>
        <ul class="text-sm space-y-1 text-[var(--color-subtle)]">
          <li>Belgium - Up to 50% + high social security</li>
          <li>Denmark - Up to 52% total tax rate</li>
          <li>Sweden - Up to 52% including local taxes</li>
          <li>Germany - Up to 45% + solidarity surcharge</li>
          <li>France - Up to 45% + high contributions</li>
        </ul>
      </div>
    </div>
    <p class="mt-4 text-sm text-[var(--color-muted)]">
      Note: Higher tax countries often provide more public services, healthcare, education, and
      social safety nets.
    </p>
  </ContentSection>

  <ContentSection title="EUR 50,000 Salary: What You Actually Take Home in 3 Countries">
    <p>
      A gross salary of EUR 50,000 per year looks the same on paper across Europe. But once your
      employer deducts income tax and social security contributions, the numbers diverge sharply.
      Here is what a single person with no children, no special deductions, and a standard
      employment contract would take home in three major economies in 2025.
    </p>
    <div class="overflow-x-auto mt-4">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-[var(--color-border)]">
            <th class="text-left py-2 pr-4 font-semibold text-[var(--color-cream)]">Country</th>
            <th class="text-right py-2 pr-4 font-semibold text-[var(--color-cream)]">Gross</th>
            <th class="text-right py-2 pr-4 font-semibold text-[var(--color-cream)]">Income Tax</th>
            <th class="text-right py-2 pr-4 font-semibold text-[var(--color-cream)]">Social Sec.</th
            >
            <th class="text-right py-2 font-semibold text-green-400">Net Take-Home</th>
          </tr>
        </thead>
        <tbody class="text-[var(--color-subtle)]">
          <tr class="border-b border-[var(--color-border)]/50">
            <td class="py-2 pr-4 font-medium text-[var(--color-cream)]">Germany</td>
            <td class="text-right py-2 pr-4">EUR 50,000</td>
            <td class="text-right py-2 pr-4">~EUR 10,300</td>
            <td class="text-right py-2 pr-4">~EUR 10,200</td>
            <td class="text-right py-2 text-green-400 font-semibold">~EUR 29,500</td>
          </tr>
          <tr class="border-b border-[var(--color-border)]/50">
            <td class="py-2 pr-4 font-medium text-[var(--color-cream)]">Netherlands</td>
            <td class="text-right py-2 pr-4">EUR 50,000</td>
            <td class="text-right py-2 pr-4">~EUR 12,800</td>
            <td class="text-right py-2 pr-4">~EUR 3,100</td>
            <td class="text-right py-2 text-green-400 font-semibold">~EUR 34,100</td>
          </tr>
          <tr>
            <td class="py-2 pr-4 font-medium text-[var(--color-cream)]">France</td>
            <td class="text-right py-2 pr-4">EUR 50,000</td>
            <td class="text-right py-2 pr-4">~EUR 7,800</td>
            <td class="text-right py-2 pr-4">~EUR 11,400</td>
            <td class="text-right py-2 text-green-400 font-semibold">~EUR 30,800</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-sm text-[var(--color-muted)]">
      Figures are estimates for a single earner with no children using standard 2025 rates. Germany
      includes the solidarity surcharge. Netherlands figures include the general tax credit
      (algemene heffingskorting). France employee social contributions are high but the income tax
      bands are more generous at this level. Your actual net will vary based on your personal
      situation.
    </p>
    <p class="mt-3 text-[var(--color-subtle)]">
      The headline finding: the Netherlands comes out EUR 4,600 ahead of Germany annually on the
      same gross salary. That is nearly EUR 380 more per month, purely from tax structure
      differences.
    </p>
  </ContentSection>

  <ContentSection title="Cost of Living vs Take-Home Pay">
    <p>
      Net salary figures only tell you what lands in your bank account. They do not tell you what
      that money buys. A EUR 34,000 net salary in Amsterdam and a EUR 29,500 net in Munich feel very
      different once you factor in rent, transport, and daily costs.
    </p>
    <h3 class="text-lg font-semibold mt-4 mb-2">What to compare alongside net pay</h3>
    <ul class="list-disc list-inside space-y-2 text-[var(--color-subtle)]">
      <li>
        <strong class="text-[var(--color-cream)]">Rent:</strong> A one-bedroom flat in Amsterdam city
        centre costs around EUR 1,800-2,200/month. In Munich it is EUR 1,500-1,900/month. Paris central
        is EUR 1,400-1,800/month. These three cities are relatively close, but secondary cities in each
        country are much cheaper.
      </li>
      <li>
        <strong class="text-[var(--color-cream)]">Healthcare:</strong> In France and Germany, statutory
        health insurance covers most costs with small co-payments. In the Netherlands you pay a mandatory
        excess (eigen risico) of EUR 385 per year before coverage kicks in, plus a monthly premium of
        around EUR 130-160.
      </li>
      <li>
        <strong class="text-[var(--color-cream)]">Transport:</strong> Germany's Deutschlandticket gives
        nationwide public transport for EUR 58/month. The Netherlands has good rail coverage but monthly
        passes vary by route. France has the Navigo pass in Paris at around EUR 86/month.
      </li>
      <li>
        <strong class="text-[var(--color-cream)]">Childcare:</strong> France has heavily subsidised creches
        (EUR 200-400/month). Germany's Kita costs depend on the state and family income. Dutch childcare
        is expensive (EUR 900-1,400/month per child) though the government reimburses a significant portion.
      </li>
    </ul>
    <p class="mt-4 text-[var(--color-subtle)]">
      The practical upshot: if you are choosing between a job offer in Amsterdam vs Munich, compare
      the net salary after your main fixed costs rather than raw take-home pay. For most single
      professionals, the Netherlands' tax credit system and Germany's lower rents outside major
      cities can narrow the gap considerably.
    </p>
  </ContentSection>

  <FAQSection faqs={faqs} />
</CalculatorLayout>
