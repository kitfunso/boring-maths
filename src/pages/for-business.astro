---
/**
 * B2B Landing Page - Sponsored Placements & Embeddable Calculators
 *
 * /for-business - Two offerings:
 * 1. Sponsored placements: businesses pay to feature their products on relevant calculators
 * 2. Embeddable widgets: businesses embed calculators on their own sites
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SnippetGenerator from '../components/embed/SnippetGenerator';

const title = 'Advertise on Our Calculators | Boring Math for Business';
const description =
  'Put your products in front of high-intent users. Sponsored placements on 149 calculators, or embed our tools on your site. Reach people at the moment they calculate.';

const sponsorExamples = [
  {
    calculator: 'Mortgage Calculator',
    business: 'Banks & brokers',
    example: 'Your mortgage products shown to users actively calculating repayments.',
    slug: 'mortgage-calculator',
  },
  {
    calculator: 'UK Pension Calculator',
    business: 'Pension providers',
    example: 'Your pension plans featured alongside retirement projections.',
    slug: 'uk-pension-calculator',
  },
  {
    calculator: 'Compound Interest Calculator',
    business: 'ISA & investment platforms',
    example: 'Your investment products shown to users exploring compound growth.',
    slug: 'compound-interest-calculator',
  },
  {
    calculator: 'Loan Calculator',
    business: 'Lenders & comparison sites',
    example: 'Your loan products shown to users calculating repayment options.',
    slug: 'loan-calculator',
  },
  {
    calculator: 'UK Stamp Duty Calculator',
    business: 'Estate agents & conveyancers',
    example: 'Your services shown to users calculating property purchase costs.',
    slug: 'uk-stamp-duty-calculator',
  },
  {
    calculator: 'FIRE Calculator',
    business: 'Investment platforms',
    example: 'Your funds and ISAs shown to users planning early retirement.',
    slug: 'fire-calculator',
  },
];

const embedCalculators = [
  {
    slug: 'mortgage-calculator',
    title: 'Mortgage Calculator',
    description: 'Monthly payments, total interest, and amortisation schedules.',
    category: 'Finance',
  },
  {
    slug: 'compound-interest-calculator',
    title: 'Compound Interest',
    description: 'See how investments grow over time with compounding.',
    category: 'Finance',
  },
  {
    slug: 'bmi-calculator',
    title: 'BMI Calculator',
    description: 'Body mass index with healthy weight ranges.',
    category: 'Health',
  },
  {
    slug: 'tip-calculator',
    title: 'Tip Calculator',
    description: 'Calculate tips and split bills between friends.',
    category: 'Everyday',
  },
  {
    slug: 'loan-calculator',
    title: 'Loan Calculator',
    description: 'Monthly payments and total interest for any loan.',
    category: 'Finance',
  },
  {
    slug: 'fire-calculator',
    title: 'FIRE Calculator',
    description: 'Financial independence projections with Lean, Fat, and Coast FIRE.',
    category: 'Finance',
  },
  {
    slug: 'uk-100k-tax-trap-calculator',
    title: 'UK £100k Tax Trap',
    description: 'Calculate how the 60% marginal rate affects your take-home pay.',
    category: 'UK Tax',
  },
  {
    slug: 'uk-pension-calculator',
    title: 'UK Pension',
    description: 'Project your retirement pot with employer and personal contributions.',
    category: 'Finance',
  },
  {
    slug: 'uk-stamp-duty-calculator',
    title: 'UK Stamp Duty',
    description: 'SDLT, LBTT, and LTT calculations for property purchases.',
    category: 'UK Tax',
  },
  {
    slug: 'uk-tax-calculator',
    title: 'UK Tax Calculator',
    description: 'Income tax, National Insurance, and take-home pay for any salary.',
    category: 'UK Tax',
  },
];

const contactEmail = 'support@boring-math.com';
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="relative py-16 md:py-24 overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-headline md:text-display mb-6">
        Reach people at the<br />
        <span class="gradient-text">moment they calculate</span>
      </h1>
      <p class="text-body-lg text-[var(--color-subtle)] max-w-2xl mx-auto mb-10">
        149 free calculators across finance, health, and more. Every user is actively making a
        decision. Put your products where they matter.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#sponsored" class="btn-primary">
          Sponsored placements
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <a href="#embeds" class="btn-secondary">Embed our calculators</a>
      </div>
    </div>
  </section>

  <!-- Why It Works -->
  <section class="py-10 md:py-16">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bento-card p-6 text-center">
          <h3 class="text-lg font-display text-[var(--color-cream)] mb-2">High intent</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Someone calculating mortgage repayments is closer to buying a house than someone reading a
            blog post about mortgages.
          </p>
        </div>
        <div class="bento-card p-6 text-center">
          <h3 class="text-lg font-display text-[var(--color-cream)] mb-2">Perfect context</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Your product appears right next to the calculation it solves. A bank's mortgage deal shown
            alongside a mortgage calculation.
          </p>
        </div>
        <div class="bento-card p-6 text-center">
          <h3 class="text-lg font-display text-[var(--color-cream)] mb-2">Exclusive placement</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            One sponsor per calculator. No competing ads. Your product is the recommendation, not one
            of twenty in a sidebar.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsored Placements -->
  <section id="sponsored" class="py-10 md:py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-headline text-center mb-4">Sponsored placements</h2>
      <p class="text-center text-[var(--color-subtle)] mb-10 max-w-2xl mx-auto">
        Your product featured on the calculator page that matches it. Users see your offer right
        after they get their result. One sponsor per calculator, no auction, no competing ads.
      </p>

      <!-- How Sponsored Placements Work -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="relative bento-card p-6 text-center">
          <div
            class="w-12 h-12 rounded-xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display text-[var(--color-accent)]">1</span>
          </div>
          <h3 class="text-lg font-display text-[var(--color-cream)] mb-2">Pick your calculator</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Choose the calculator that matches your product. Mortgage calculator for lenders, pension
            calculator for pension providers, and so on.
          </p>
        </div>
        <div class="relative bento-card p-6 text-center">
          <div
            class="w-12 h-12 rounded-xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display text-[var(--color-accent)]">2</span>
          </div>
          <h3 class="text-lg font-display text-[var(--color-cream)] mb-2">We feature your product</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Your product appears in a dedicated recommendation section below the calculator results.
            Your brand, your description, your call to action.
          </p>
        </div>
        <div class="relative bento-card p-6 text-center">
          <div
            class="w-12 h-12 rounded-xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display text-[var(--color-accent)]">3</span>
          </div>
          <h3 class="text-lg font-display text-[var(--color-cream)] mb-2">Users click through</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Every click tracked and reported monthly. Real users who just ran the numbers and want to
            take the next step.
          </p>
        </div>
      </div>

      <!-- Available Calculators for Sponsorship -->
      <h3 class="text-xl font-display text-[var(--color-cream)] text-center mb-8">
        Available for sponsorship
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        {
          sponsorExamples.map((item) => (
            <div class="bento-card p-6">
              <div class="flex items-center justify-between mb-3">
                <h4 class="font-display text-[var(--color-cream)]">{item.calculator}</h4>
                <span class="text-xs px-2 py-0.5 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-emerald-400">
                  Available
                </span>
              </div>
              <p class="text-sm text-[var(--color-muted)] mb-2">
                <span class="text-[var(--color-subtle)]">Ideal for:</span> {item.business}
              </p>
              <p class="text-sm text-[var(--color-subtle)]">{item.example}</p>
            </div>
          ))
        }
      </div>

      <!-- Sponsored Placement Pricing -->
      <div class="max-w-2xl mx-auto">
        <div class="bento-card p-8 md:p-10">
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-6 text-center">
            Sponsorship pricing
          </h3>
          <div class="space-y-6">
            <div class="flex items-start justify-between gap-4 pb-4 border-b border-white/5">
              <div>
                <p class="font-medium text-[var(--color-cream)]">Single calculator</p>
                <p class="text-sm text-[var(--color-muted)] mt-1">
                  Your product featured on one calculator page
                </p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xl font-display text-[var(--color-cream)]">
                  &pound;49<span class="text-sm text-[var(--color-muted)]">/month</span>
                </p>
              </div>
            </div>
            <div class="flex items-start justify-between gap-4 pb-4 border-b border-white/5">
              <div>
                <p class="font-medium text-[var(--color-cream)]">Category bundle</p>
                <p class="text-sm text-[var(--color-muted)] mt-1">
                  All calculators in a category (e.g. all UK tax calculators)
                </p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xl font-display text-[var(--color-cream)]">
                  &pound;149<span class="text-sm text-[var(--color-muted)]">/month</span>
                </p>
              </div>
            </div>
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium text-[var(--color-cream)]">Exclusive partner</p>
                <p class="text-sm text-[var(--color-muted)] mt-1">
                  All finance calculators site-wide. One partner, maximum reach.
                </p>
              </div>
              <div class="text-right shrink-0">
                <p class="text-xl font-display text-[var(--color-cream)]">Custom</p>
              </div>
            </div>
          </div>
          <div class="mt-8 text-center">
            <a
              href={`mailto:${contactEmail}?subject=Sponsored%20Placement%20Enquiry`}
              class="btn-primary"
            >
              Get started
            </a>
            <p class="text-xs text-[var(--color-muted)] mt-3">
              All placements include monthly click reports and are clearly marked as sponsored
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Demo: What a Sponsored Placement Looks Like -->
