  <section id="pricing" class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-headline text-center mb-4">Simple pricing</h2>
      <p class="text-center text-[var(--color-subtle)] mb-16 max-w-lg mx-auto">
        Start embedding for free. Upgrade when you need custom branding or dedicated support.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Free Tier -->
        <div class="bento-card p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-xl font-display text-[var(--color-cream)] mb-1">Free</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-display text-[var(--color-cream)]">&pound;0</span>
              <span class="text-sm text-[var(--color-muted)]">/month</span>
            </div>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              Embed any calculator
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              Responsive iframe
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              &ldquo;Powered by&rdquo; badge required
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
