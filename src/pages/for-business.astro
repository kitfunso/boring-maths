              <div class="flex items-center justify-between mb-2">
                <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-[var(--color-muted)]">
                  {calc.category}
                </span>
              </div>
              <h3 class="text-base font-display text-[var(--color-cream)] mb-1 group-hover:text-[var(--color-accent)] transition-colors">
                {calc.title}
              </h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{calc.description}</p>
