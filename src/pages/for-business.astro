      <h2 class="text-headline text-center mb-4">Embed builder</h2>
      <p class="text-center text-[var(--color-subtle)] mb-12 max-w-lg mx-auto">
        Pick a calculator, set the size, and copy the code. Done.
      </p>
      <div class="bento-card p-6 md:p-8">
        <SnippetGenerator client:load />
      </div>
    </div>
  </section>

  <!-- Calculator Showcase -->
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-headline text-center mb-4">Popular calculators</h2>
      <p class="text-center text-[var(--color-subtle)] mb-12 max-w-lg mx-auto">
        Browse some of our most embedded tools. Click any card to load it in the builder above.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          showcaseCalculators.map((calc) => (
            <a
              href={`#embed-builder`}
              class="bento-card p-5 group"
              data-calc-slug={calc.slug}
              aria-label={`Preview ${calc.title} embed`}
