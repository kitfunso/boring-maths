---
/**
 * B2B Landing Page - Embeddable Calculators for Business
 *
 * /for-business - Landing page for businesses wanting to embed calculators
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SnippetGenerator from '../components/embed/SnippetGenerator';

const title = 'Embed Calculators on Your Website | Boring Math for Business';
const description =
  'Add free, embeddable calculators to your website. 149 tools for finance, health, engineering and more. One line of HTML. Works on any site.';

// Only showcase calculators that have embed pages
const showcaseCalculators = [
  {
    slug: 'mortgage-calculator',
    title: 'Mortgage Calculator',
    description: 'Monthly payments, total interest, and amortisation schedules.',
    category: 'Finance',
  },
  {
    slug: 'compound-interest-calculator',
    title: 'Compound Interest',
    description: 'See how investments grow over time with compounding.',
    category: 'Finance',
  },
  {
    slug: 'bmi-calculator',
    title: 'BMI Calculator',
    description: 'Body mass index with healthy weight ranges.',
    category: 'Health',
  },
  {
    slug: 'tip-calculator',
    title: 'Tip Calculator',
    description: 'Calculate tips and split bills between friends.',
    category: 'Everyday',
  },
  {
    slug: 'loan-calculator',
    title: 'Loan Calculator',
    description: 'Monthly payments and total interest for any loan.',
    category: 'Finance',
  },
  {
    slug: 'fire-calculator',
    title: 'FIRE Calculator',
    description: 'Financial independence projections with Lean, Fat, and Coast FIRE.',
    category: 'Finance',
  },
  {
    slug: 'uk-100k-tax-trap-calculator',
    title: 'UK £100k Tax Trap',
    description: 'Calculate how the 60% marginal rate affects your take-home pay.',
    category: 'UK Tax',
  },
  {
    slug: 'uk-pension-calculator',
    title: 'UK Pension',
    description: 'Project your retirement pot with employer and personal contributions.',
    category: 'Finance',
  },
  {
    slug: 'uk-stamp-duty-calculator',
    title: 'UK Stamp Duty',
    description: 'SDLT, LBTT, and LTT calculations for property purchases.',
    category: 'UK Tax',
  },
  {
    slug: 'uk-tax-calculator',
    title: 'UK Tax Calculator',
    description: 'Income tax, National Insurance, and take-home pay for any salary.',
    category: 'UK Tax',
  },
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <section class="relative py-24 md:py-32 overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 text-center">
      <h1 class="text-headline md:text-display mb-6">
        Add our calculators<br />
        <span class="gradient-text">to your website</span>
      </h1>
      <p class="text-body-lg text-[var(--color-subtle)] max-w-2xl mx-auto mb-10">
        149 free, embeddable calculators. Finance, health, engineering, and more. Your readers get
        the tools, you get the engagement.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#embed-builder" class="btn-primary">
          Try the embed builder
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"
            ></path>
          </svg>
        </a>
        <a href="#pricing" class="btn-secondary"> View pricing </a>
      </div>
    </div>
  </section>

  <!-- Live Embed Demo -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-6">
      <div
        class="rounded-2xl border border-white/10 overflow-hidden bg-[var(--color-night)] shadow-2xl"
      >
        <!-- Browser chrome -->
        <div
          class="flex items-center gap-2 px-4 py-3 bg-[var(--color-charcoal)] border-b border-white/5"
        >
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
          </div>
          <div class="flex-1 mx-4">
            <div
              class="px-3 py-1.5 bg-[var(--color-night)] rounded-lg text-xs text-[var(--color-muted)] font-mono truncate"
            >
              https://your-website.com/tools
            </div>
          </div>
        </div>
        <!-- Iframe preview -->
        <div class="p-4 md:p-6 bg-white/[0.02]">
          <iframe
            src="/embed/mortgage-calculator"
            width="100%"
            height="600"
            frameborder="0"
            style="border:none;border-radius:12px;"
            loading="lazy"
            title="Mortgage Calculator embed demo"></iframe>
        </div>
      </div>
      <p class="text-center text-sm text-[var(--color-muted)] mt-4">
        Live preview: Mortgage Calculator embedded on your site
      </p>
    </div>
  </section>

  <!-- How it Works -->
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-headline text-center mb-16">How it works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Step 1 -->
        <div class="relative bento-card p-8 text-center">
          <div
            class="w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-5"
          >
            <span class="text-2xl font-display text-[var(--color-accent)]">1</span>
          </div>
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-3">Pick a calculator</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Choose from 149 tools across finance, health, engineering, everyday math, and more.
          </p>
        </div>
        <!-- Step 2 -->
        <div class="relative bento-card p-8 text-center">
          <div
            class="w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-5"
          >
            <span class="text-2xl font-display text-[var(--color-accent)]">2</span>
          </div>
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-3">Copy the code</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            One line of HTML. Configure width and height if you want, then copy.
          </p>
        </div>
        <!-- Step 3 -->
        <div class="relative bento-card p-8 text-center">
          <div
            class="w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 border border-[var(--color-accent)]/20 flex items-center justify-center mx-auto mb-5"
          >
            <span class="text-2xl font-display text-[var(--color-accent)]">3</span>
          </div>
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-3">Paste and publish</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Works on any website. WordPress, Webflow, Squarespace, custom HTML, you name it.
          </p>
        </div>
      </div>
    </div>
  </section>

