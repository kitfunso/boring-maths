          </ul>
          <a
            href={`mailto:${contactEmail}?subject=Boring%20Math%20Enterprise%20Embed%20Enquiry`}
            class="btn-secondary w-full text-center"
          >
            Contact us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Embed Builder -->
  <section id="embed-builder" class="py-10 md:py-16 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-headline text-center mb-4">Embed builder</h2>
      <p class="text-center text-[var(--color-subtle)] mb-8 max-w-lg mx-auto">
        Pick a calculator, set the size, and copy the code.
      </p>
      <div class="bento-card p-6 md:p-8">
        <SnippetGenerator client:load />
      </div>
    </div>
  </section>

  <!-- Calculator Showcase -->
  <section class="py-10 md:py-16">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-headline text-center mb-4">Available calculators</h2>
      <p class="text-center text-[var(--color-subtle)] mb-8 max-w-lg mx-auto">
        Sponsor or embed any of these. Click a card to load it in the embed builder.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {
          embedCalculators.map((calc) => (
            <a
              href="#embed-builder"
              class="bento-card p-5 group"
              data-calc-slug={calc.slug}
              aria-label={`Preview ${calc.title}`}
            >
              <div class="flex items-center justify-between mb-2">
                <span class="text-xs px-2 py-0.5 rounded-full bg-white/5 border border-white/10 text-[var(--color-muted)]">
                  {calc.category}
                </span>
              </div>
              <h3 class="text-base font-display text-[var(--color-cream)] mb-1 group-hover:text-[var(--color-accent)] transition-colors">
                {calc.title}
              </h3>
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{calc.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-10 md:py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-headline mb-4">Questions?</h2>
      <p class="text-[var(--color-subtle)] mb-8">
        Drop us an email. We typically reply within a working day.
      </p>
      <a
        href={`mailto:${contactEmail}?subject=Boring%20Math%20Business%20Enquiry`}
        class="btn-primary"
      >
        Email {contactEmail}
      </a>
    </div>
  </section>
</BaseLayout>
