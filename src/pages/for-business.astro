              <span class="text-sm text-[var(--color-muted)]">/month</span>
            </div>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              Embed any calculator
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              Responsive iframe
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              Badge removed
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg
                class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
