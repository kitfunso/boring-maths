            </div>
          </div>
        </div>
        <div class="p-6 md:p-8">
          <!-- Mock sponsored placement -->
          <div class="glass rounded-2xl p-6">
            <p class="text-micro text-[var(--color-accent)] mb-3">Recommended</p>
            <h3 class="text-lg font-display text-[var(--color-cream)] mb-4">
              Compare Mortgage Deals
            </h3>
            <div class="space-y-3">
              <div
                class="block bg-[var(--color-night)] rounded-xl p-4 border border-white/5 hover:border-[var(--color-accent)]/30 transition-all duration-300"
              >
                <div class="flex items-center justify-between gap-4">
                  <div class="flex-1 min-w-0">
                    <h4 class="font-medium text-[var(--color-cream)]">Your Brand Here</h4>
                    <p class="text-sm text-[var(--color-subtle)] mt-1">
                      Your product description. "Compare 20,000+ mortgage deals from 90+ lenders.
                      Free, whole-of-market advice."
                    </p>
                  </div>
                  <span
                    class="text-[var(--color-accent)] font-medium text-sm whitespace-nowrap flex items-center gap-1"
                  >
                    Your CTA
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                    </svg>
                  </span>
                </div>
              </div>
            </div>
            <p class="text-xs text-[var(--color-muted)] mt-4">
              * Sponsored placement.
              <a href="/affiliate-disclosure" class="text-[var(--color-accent)] hover:underline"
                >Learn more</a
              >
            </p>
          </div>
        </div>
      </div>
      <p class="text-center text-sm text-[var(--color-muted)] mt-4">
        Example: Sponsored placement on the Mortgage Calculator page
      </p>
    </div>
  </section>

  <!-- Embed Section -->
  <section id="embeds" class="py-10 md:py-16 border-t border-white/5">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-headline text-center mb-4">Embed our calculators</h2>
      <p class="text-center text-[var(--color-subtle)] mb-10 max-w-2xl mx-auto">
        Add any of our calculators to your own website. One line of HTML. Free with a small
        "Powered by" badge, or white-label for a clean integration.
      </p>

      <!-- How Embeds Work -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="relative bento-card p-6 text-center">
          <div
            class="w-12 h-12 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display text-violet-400">1</span>
          </div>
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-3">Pick a calculator</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Choose from 149 tools across finance, health, engineering, everyday math, and more.
          </p>
        </div>
        <div class="relative bento-card p-6 text-center">
          <div
            class="w-12 h-12 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display text-violet-400">2</span>
          </div>
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-3">Copy the code</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            One line of HTML. Configure width and height if you want, then copy.
          </p>
        </div>
        <div class="relative bento-card p-6 text-center">
          <div
            class="w-12 h-12 rounded-xl bg-violet-500/10 border border-violet-500/20 flex items-center justify-center mx-auto mb-4"
          >
            <span class="text-2xl font-display text-violet-400">3</span>
          </div>
          <h3 class="text-xl font-display text-[var(--color-cream)] mb-3">Paste and publish</h3>
          <p class="text-sm text-[var(--color-subtle)]">
            Works on any website. WordPress, Webflow, Squarespace, custom HTML.
          </p>
        </div>
      </div>

      <!-- Embed Pricing -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
