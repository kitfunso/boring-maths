          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Embed any calculator
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Responsive iframe
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              &ldquo;Powered by&rdquo; badge
            </li>
          </ul>
          <a href="#embed-builder" class="btn-secondary w-full text-center">Start embedding</a>
        </div>

        <!-- Pro Tier -->
        <div class="bento-card p-6 flex flex-col border-[var(--color-accent)]/30 ring-1 ring-[var(--color-accent)]/20">
          <div class="mb-4">
            <span class="inline-block px-3 py-1 text-xs font-medium bg-[var(--color-accent)] text-[var(--color-void)] rounded-full mb-3">
              Most Popular
            </span>
          </div>
          <div class="mb-4">
            <h3 class="text-xl font-display text-[var(--color-cream)] mb-1">Pro</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-display text-[var(--color-cream)]">&pound;29</span>
              <span class="text-sm text-[var(--color-muted)]">/month</span>
            </div>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Everything in Free
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Badge removed (white-label)
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Custom colours
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              5 domains
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-subtle)]">
              <svg class="w-5 h-5 text-[var(--color-accent)] shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              Priority support
            </li>
          </ul>
          <a
            href={`mailto:${contactEmail}?subject=Boring%20Math%20Pro%20Embed%20Enquiry`}
            class="btn-primary w-full text-center"
