              SLA
            </li>
          </ul>
          <a
            href="mailto:keith@boring-math.com?subject=Boring%20Math%20Pro%20%E2%80%93%20Enquiry"
            class="btn-primary w-full text-center"
          >
            Contact us
          </a>
        </div>

        <!-- Enterprise Tier -->
        <div class="bento-card p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-xl font-display text-[var(--color-cream)] mb-1">Enterprise</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-display text-[var(--color-cream)]">Custom</span>
