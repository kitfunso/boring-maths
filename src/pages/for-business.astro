            <li class="flex items-start gap-3 text-sm text-[var(--color-muted)]">
              <svg
                class="w-5 h-5 text-[var(--color-muted)]/40 shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"></path></svg
              >
              Priority support
            </li>
          </ul>
          <a href="#embed-builder" class="btn-secondary w-full text-center"> Start embedding </a>
        </div>

        <!-- Pro Tier (highlighted) -->
        <div
          class="relative bento-card overflow-visible p-8 flex flex-col border-[var(--color-accent)]/30 ring-1 ring-[var(--color-accent)]/20"
        >
          <div class="absolute -top-3 left-1/2 -translate-x-1/2">
            <span
              class="px-4 py-1 text-xs font-medium bg-[var(--color-accent)] text-[var(--color-void)] rounded-full"
